# === UCS-Training ===
# Этот файл — шаблон. Не коммить реальные значения!
# Скопируй в .env.local и заполни для локальной разработки.

# --- Frontend ---
# API URL бэкенда (NestJS, порт 4000)
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Backend ---
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ucs_trainings
DIRECT_URL=postgresql://user:password@localhost:5432/ucs_trainings

# Auth (JWT)
JWT_SECRET=replace-with-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

# CORS
FRONTEND_URL=http://localhost:3000
PORT=4000
LOG_LEVEL=info
